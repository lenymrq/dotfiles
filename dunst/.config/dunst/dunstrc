[global]
frame_width = 2
frame_color = "#4C7899"
separator_color = frame

background = "#222222"
foreground = "#B2C2CE"

origin = top-center
alignment = center

height = (150, 300)
width = (240, 960)

font = "Inter 12"

[urgency_low]
timeout = 5

[urgency_normal]
timeout = 10

[urgency_critical]
frame_color = "#EC69A0"
timeout = 0
