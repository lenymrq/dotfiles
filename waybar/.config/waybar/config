{
    "layer": "top",
    "position": "bottom",
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["sway/window"],
    "modules-right": ["cpu","memory", "pulseaudio", "backlight", "battery", "network", "tray", "clock"],
    "sway/window": {
        "max-length": 64
    },
    "sway/workspaces": {
      "disable-scroll": true
    },
    "backlight": {
        "format": "bri {percent}%"
    },
    "battery": {
        "format": "bat {capacity}%"
    },
    "clock": {
        "format-alt": "{:%a, %d. %b  %H:%M}",
        "tooltip": false
    },
    "pulseaudio": {
        "scroll-step": 5,
        "max-volume": 150,
        "format": "vol {volume}%",
        "format-muted": "mut {volume}%",
        "nospacing": 1,
        "on-click": "pavucontrol",
        "tooltip": false
    },
    "cpu": {
        "interval": 10,
        "format": "cpu {usage}%",
        "max-length": 10
    },
    "memory": {
        "interval": 30,
        "format": "mem {percentage}%",
        "max-length": 10
    },
    "network": {
        "format": "net {ifname}",
        "format-wifi": "wifi {essid} ({signalStrength}%)",
        "format-ethernet": "eth {ipaddr}",
        "format-disconnected": "net disconnected",
        "max-length": 50
    }
}
